      </column>
      <column caption='CY PHEV' datatype='integer' name='[Calculation_1875792843730967]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Model Year] = [Parameters].[Parameter 1875792686546946]&#13;&#10;AND [Electric Vehicle Type] = &quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot;&#13;&#10;THEN [VIN (1-10)]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='PY PHEV' datatype='integer' name='[Calculation_1875792844820504]' role='measure' type='quantitative'>
