      <column caption='Total BEV Vehicles' datatype='integer' name='[Calculation_1875792841838613]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Electric Vehicle Type]= &quot;Battery Electric Vehicle (BEV)&quot; THEN&#13;&#10;[DOL Vehicle ID] END&#13;&#10;)' />
      </column>
